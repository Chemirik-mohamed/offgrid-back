enum CurrentType {
  AC
  DC
}

model Appliance {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Caractéristiques techniques (catalogue, gérées par seed)
  currentType            CurrentType @default(AC)
  voltageV               Float       @default(230)
  unitPowerW             Float
  startupPowerW          Float
  defaultDiversityFactor Float       @default(1.0)

  projectAppliances ProjectAppliance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appliance")
}

model ProjectAppliance {
  id          String @id @default(uuid())
  projectId   String
  applianceId String

  // Saisie utilisateur (modale)
  quantity    Int
  timeSlots   Json // TimeSlot[] validé par Zod
  currentType CurrentType // surchargeable depuis le catalogue

  // Snapshot catalogue à la création (figé pour les calculs)
  voltageVSnapshot               Float
  unitPowerWSnapshot             Float
  startupPowerWSnapshot          Float
  defaultDiversityFactorSnapshot Float

  // Ajustement expert Surtec (avant calcul)
  diversityFactorOverride Float?

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  appliance Appliance @relation(fields: [applianceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_appliance")
}

model Category {
  id           String      @id @default(uuid())
  slug         String      @unique
  label        String
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  appliances   Appliance[]

  @@map("category")
}
