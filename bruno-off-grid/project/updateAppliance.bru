meta {
  name: updateAppliance
  type: http
  seq: 8
}

patch {
  url: http://localhost:3000/api/project/{{projectId}}/appliance/{{projectApplianceId}}
  body: json
  auth: inherit
}

body:json {
  {
    "quantity": 3,
    "currentType": "AC",
    "timeSlots": [
      {
        "label": "evening",
        "from": "18:00:00",
        "to": "22:00:00"
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
